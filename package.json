{
  "name": "tanstack-start-example-basic-cloudflare",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "postinstall": "pnpm run cf-typegen",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply starter_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply starter_db --remote",
    "auth:generate": "pnpm dlx auth@latest generate --config ./src/lib/auth.ts --yes"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-start": "^1.166.16",
    "better-auth": "^1.4.2",
    "drizzle-orm": "^0.44.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.7",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.6.0",
    "drizzle-kit": "^0.31.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.49.1"
  }
}
